---
import SocialList from "@/components/SocialList.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import PageLayout from "@/layouts/Base.astro";
import { getAllPosts, sortMDByDate } from "@/utils";

const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);
---

<PageLayout meta={{ title: "Home" }}>
	<section>
		<h1 class="title mb-6">Hello there!</h1>
		<p class="mb-4">
      Hello and welcome to my little corner of the web.
    </p>
    <p class="mb-4">
      I'm a 44-year-old dad of two great boys, a husband and a true generalist.
    </p>
    <p class="mb-4">
      I make a living from bending computers to my will. Things that pique my
      interst are free and open-source software, the web outside of the walled
      gardens of the main social media platforms, international relations,
      cartooning and gardening.
		</p>
    <p class="mb-4">
      My daily hobby for the past year or so is building a set of developer tools
      I collectively call <a class="cactus-link" href="https://requestbite.com"
      target="_blank">RequestBite</a>. Those ware perfectly tailored for developing,
      and integrating with, HTTP-based APIs. If you, like me, love building for
      the web - you might very well enjoy it. Go head - give it a try!
    </p>
		<SocialList />
	</section>
	<section aria-label="Blog post list" class="mt-16">
		<h2 class="title mb-4 text-xl">Posts</h2>
		<ul class="space-y-4">
			{
				allPostsByDate.map((p) => (
					<li class="flex flex-col gap-x-2 sm:flex-row">
						<PostPreview post={p} />
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>
